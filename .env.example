# Bitcoin Sentiment Trader Performance — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Data sources (local paths; defaults are in configs/base.yaml)
FEAR_GREED_PATH=data/raw/fear_greed/fear_greed_index.csv
TRADER_HISTORY_PATH=data/raw/trader_history/historical_data.csv

# Pipeline configuration
CONFIG_PATH=configs/base.yaml
LOG_LEVEL=INFO

# MLflow tracking (file-based by default; switch to remote URI for team use)
MLFLOW_TRACKING_URI=experiments/mlruns
MLFLOW_EXPERIMENT_NAME=ml_experiments

# Random seed for reproducibility (override in configs/pipelines/ml.yaml)
RANDOM_SEED=42

